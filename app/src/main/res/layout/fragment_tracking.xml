<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Imagen superior -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:src="@drawable/img_rastrea_envio"
        android:scaleType="centerCrop"/>

    <!-- Contenido -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Título -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:padding="14dp"
            android:text="@string/titulo_tracking"
            android:textColor="@color/color_letra_2"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <!-- Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="@string/label_numero_guia"
            android:textColor="@color/color_letra_2"
            android:textSize="13sp"
            android:textStyle="bold"/>

        <!-- Campo número de guía -->
        <EditText
            android:id="@+id/etNumeroGuia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_campo_texto"
            android:hint="@string/hint_guia"
            android:imeOptions="actionDone"
            android:inputType="text"
            android:maxLines="1"
            android:padding="14dp"
            android:textColor="@color/color_letra_2"
            android:textColorHint="@color/color_hint"
            android:textSize="14sp"/>

        <!-- Botón buscar -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBuscar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/btn_buscar"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@color/color_letra_1"
            app:cornerRadius="12dp"
            app:strokeWidth="0dp"/>

    </LinearLayout>

</LinearLayout>