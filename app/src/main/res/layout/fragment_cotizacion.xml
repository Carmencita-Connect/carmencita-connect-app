<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Título -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_boton_titulo"
            android:gravity="center"
            android:padding="14dp"
            android:text="@string/titulo_cotizar"
            android:textColor="@color/color_letra_2"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <!-- MEDIDAS -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="@string/label_medidas"
            android:textColor="@color/color_letra_1"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <!-- Fila medidas + imagen -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <!-- Columna campos -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_largo"
                    android:textColor="@color/color_letra_2"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
                <EditText
                    android:id="@+id/etLargo"
                    android:layout_width="115dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_campo_texto"
                    android:hint="@string/hint_largo"
                    android:imeOptions="actionNext"
                    android:inputType="numberDecimal"
                    android:maxLines="1"
                    android:padding="10dp"
                    android:textColor="@color/black"
                    android:textColorHint="@color/color_hint"
                    android:textSize="14sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_ancho"
                    android:textColor="@color/color_letra_2"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
                <EditText
                    android:id="@+id/etAncho"
                    android:layout_width="115dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_campo_texto"
                    android:hint="@string/hint_ancho"
                    android:imeOptions="actionNext"
                    android:inputType="numberDecimal"
                    android:maxLines="1"
                    android:padding="10dp"
                    android:textColor="@color/black"
                    android:textColorHint="@color/color_hint"
                    android:textSize="14sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_alto"
                    android:textColor="@color/color_letra_2"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
                <EditText
                    android:id="@+id/etAlto"
                    android:layout_width="115dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_campo_texto"
                    android:hint="@string/hint_alto"
                    android:imeOptions="actionNext"
                    android:inputType="numberDecimal"
                    android:maxLines="1"
                    android:padding="10dp"
                    android:textColor="@color/black"
                    android:textColorHint="@color/color_hint"
                    android:textSize="14sp"/>

            </LinearLayout>

            <!-- Imagen caja con etiquetas -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <ImageView
                    android:layout_width="150dp"
                    android:layout_height="130dp"
                    android:layout_gravity="center"
                    android:scaleType="fitCenter"
                    android:src="@drawable/img_caja"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:text="@string/label_alto_caja"
                    android:textColor="@color/color_letra_2"
                    android:textSize="11sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|start"
                    android:text="@string/label_ancho_caja"
                    android:textColor="@color/color_letra_2"
                    android:textSize="11sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:text="@string/label_largo_caja"
                    android:textColor="@color/color_letra_2"
                    android:textSize="11sp"
                    android:textStyle="bold"/>

            </FrameLayout>

        </LinearLayout>

        <!-- SECCIÓN PESO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="@string/label_ingresa_peso"
            android:textColor="@color/color_letra_1"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_peso_kg"
            android:textColor="@color/color_letra_2"
            android:textSize="13sp"
            android:layout_marginBottom="4dp"
            android:textStyle="bold"/>

        <EditText
            android:id="@+id/etPeso"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_campo_texto"
            android:hint="@string/hint_peso"
            android:imeOptions="actionDone"
            android:inputType="numberDecimal"
            android:maxLines="1"
            android:padding="10dp"
            android:textColor="@color/black"
            android:textColorHint="@color/color_hint"
            android:textSize="14sp"/>

        <!-- SECCIÓN ORIGEN / DESTINO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="@string/label_origen_destino"
            android:textColor="@color/color_letra_1"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <!-- Origen -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="@string/label_origen"
                    android:textColor="@color/color_letra_2"
                    android:textSize="13sp"
                    android:textStyle="bold"/>

                <Spinner
                    android:id="@+id/spinnerOrigen"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_campo_texto"
                    android:entries="@array/origenes"
                    android:padding="10dp"/>
            </LinearLayout>

            <!-- Destino -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="@string/label_destino"
                    android:textColor="@color/color_letra_2"
                    android:textSize="13sp"
                    android:textStyle="bold"/>

                <Spinner
                    android:id="@+id/spinnerDestino"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_campo_texto"
                    android:entries="@array/destinos"
                    android:padding="10dp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Error -->
        <TextView
            android:id="@+id/tvError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:gravity="center"
            android:textColor="@color/color_error"
            android:textSize="13sp"
            android:visibility="gone"/>

        <!-- Botón calcular -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCalcular"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="16dp"
            android:text="@string/btn_calcular"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@color/color_letra_1"
            app:cornerRadius="12dp"
            app:strokeWidth="0dp"/>

        <!-- Resultado -->
        <LinearLayout
            android:id="@+id/layoutResultado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_boton_titulo"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="20dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ico_sol"
                android:scaleType="fitCenter"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tarifa_estimada"
                    android:textColor="@color/color_letra_2"
                    android:textSize="13sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvTarifa"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.00"
                    android:textColor="@color/color_letra_1"
                    android:textSize="26sp"
                    android:textStyle="bold"/>

            </LinearLayout>
        </LinearLayout>

        <!-- Botón pre-registro — FUERA del resultado -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPreRegistro"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="24dp"
            android:text="@string/btn_realizar_preregistro"
            android:textColor="@color/color_letra_1"
            android:textSize="15sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:backgroundTint="@color/white"
            app:cornerRadius="12dp"
            app:strokeColor="@color/color_letra_1"
            app:strokeWidth="1.5dp"/>

    </LinearLayout>
</ScrollView>